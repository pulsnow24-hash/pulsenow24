rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// PulsNow24 — reguli Firestore (versionate în repo)
//
// Modelul de autorizare actual: un singur nivel — conturile de redacție
// create manual în Firebase Auth (nu există sign-up public și nu există
// încă roluri/custom claims). Prin urmare `isNewsroom()` = autentificat.
//
// NOTĂ DE ARHITECTURĂ (câmpuri gestionate de sistem):
// Scorurile, timeline-ul și datele agregate ale Story-urilor sunt scrise
// de pipeline-ul de import, care azi rulează în clientul autentificat al
// redacției — acesta ESTE fluxul de încredere curent. Când va exista un
// scriitor server-side (Admin SDK ocolește oricum regulile), scrierile pe
// /stories pot fi restrânse la server schimbând o singură funcție aici.
// Până atunci, regulile validează strict tipurile/intervalele acestor
// câmpuri, iar publicul nu poate scrie nimic, nicăieri.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isNewsroom() {
      return request.auth != null;
    }

    // ── Articole: citite de site-ul public, scrise de redacție ──
    match /articles/{id} {
      allow read: if true;
      allow write: if isNewsroom();
    }

    // ── Config: doar tickerul e public (site-ul îl afișează) ──
    match /config/ticker {
      allow read: if true;
      allow write: if isNewsroom();
    }
    match /config/{id} {
      allow read, write: if isNewsroom();
    }

    // ── Fluxul intern al redacției: complet privat ──
    match /inbox/{id} {
      allow read, write: if isNewsroom();
    }
    match /sources/{id} {
      allow read, write: if isNewsroom();
    }
    match /import_logs/{id} {
      allow read, write: if isNewsroom();
    }

    // ── Stories: activul central ──
    // Citire publică (necesară viitoarelor pagini Live Story / Timeline /
    // Breaking / Entitate). Scriere doar de redacție, cu validare de schemă.
    function scoreOk(v) {
      return v is number && v >= 0 && v <= 100;
    }
    function validStory() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'title', 'status', 'summary', 'categorie', 'timeline',
          'articleIds', 'sources', 'signalCount',
          'entities', 'people', 'locations', 'organizations',
          'trustScore', 'importanceScore', 'breakingScore', 'localityScore',
          'countryCode', 'coverImage', 'createdAt', 'lastUpdated'
        ])
        && d.title is string && d.title.size() > 0 && d.title.size() <= 200
        && d.status in ['developing', 'breaking', 'confirmed', 'archived']
        && d.summary is string && d.summary.size() <= 2000
        && d.categorie is string
        && d.timeline is list && d.timeline.size() <= 100
        && d.articleIds is list
        && d.sources is list
        && d.signalCount is number && d.signalCount >= 0
        && d.entities is list && d.people is list
        && d.locations is list && d.organizations is list
        && scoreOk(d.trustScore)
        && scoreOk(d.importanceScore)
        && scoreOk(d.breakingScore)
        && scoreOk(d.localityScore)
        && d.countryCode is string && d.countryCode.size() <= 2
        && (!('coverImage' in d) || d.coverImage is string)
        && d.createdAt is string && d.lastUpdated is string;
    }
    match /stories/{id} {
      allow read: if true;
      allow create, update: if isNewsroom() && validStory();
      allow delete: if isNewsroom();
    }

    // ── Entities: noduri de cunoaștere reutilizabile ──
    // Citire publică (viitoarele pagini de entitate). Scriere doar redacție,
    // cu validare de tipuri pe câmpurile agregate.
    function validEntity() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 120
        && d.type in ['person', 'organization', 'institution', 'company',
                      'party', 'country', 'county', 'city', 'location',
                      'product', 'crypto', 'law', 'event']
        && d.aliases is list && d.aliases.size() <= 30
        && d.mentionCount is number && d.mentionCount >= 0
        && d.relatedStoryIds is list
        && d.relatedArticleIds is list
        && d.relatedEntityIds is list
        && scoreOk(d.trendScore)
        && scoreOk(d.importanceScore)
        && d.firstSeen is string && d.lastSeen is string
        && d.dailyMentions is map;
    }
    match /entities/{id} {
      allow read: if true;
      // request.resource.data e documentul rezultat (merged), deci validarea
      // acoperă și update-urile parțiale (ex: arrayUnion pe relatedArticleIds)
      allow create, update: if isNewsroom() && validEntity();
      allow delete: if isNewsroom();
    }

    // ── Monitor local: alertele sunt inteligență INTERNĂ — niciodată publice ──
    function validAlert() {
      let d = request.resource.data;
      return d.workspace is string
        && d.type in ['institution-announcement','emergency','infrastructure','funding','investment','negative-spike','public-interest','breaking-local']
        && d.severity in ['info','attention','urgent']
        && d.status in ['new','read','dismissed']
        && d.title is string && d.title.size() > 0 && d.title.size() <= 200
        && d.message is string && d.message.size() <= 500
        && d.itemId is string && d.at is string
        && d.institutions is list;
    }
    match /alerts/{id} {
      allow read: if isNewsroom();
      allow create, update: if isNewsroom() && validAlert();
      allow delete: if isNewsroom();
    }

    // ── Acoperirea story-urilor (source-neutrality) — internă ──
    function validCoverage() {
      let d = request.resource.data;
      return d.workspace is string
        && d.independentSources is number && d.independentSources >= 0
        && d.officialCount is number && d.pressCount is number && d.socialCount is number
        && d.corroborated is bool && d.singleSource is bool
        && scoreOk(d.diversityScore)
        && d.conflict in ['unchecked','consistent','conflicting']
        && (!('consistencyDetail' in d) || d.consistencyDetail in ['consistent','complementary','update','contradiction'])
        && (!('confidence' in d) || scoreOk(d.confidence))
        && (!('confidenceLabel' in d) || d.confidenceLabel in ['high','medium','low'])
        && (!('mergeSuggestion' in d) || (d.mergeSuggestion is map && d.mergeSuggestion.status in ['open','dismissed']))
        && d.updatedAt is string;
    }
    match /story_coverage/{id} {
      allow read: if isNewsroom();
      allow create, update: if isNewsroom() && validCoverage();
      allow delete: if isNewsroom();
    }

    // ── Stare editorială (workflow) — SEPARATĂ de dovezi, internă ──
    // Documentul e legat de un storyId (== id-ul documentului) și un
    // workspace valid; validăm status, followed, timestamps, notes și
    // structura opțională snapshot/draft. Fiind colecție separată, o scriere
    // aici nu poate atinge stories/alerts/story_coverage/entities.
    function validWorkflow(id) {
      let d = request.resource.data;
      return d.storyId is string && d.storyId == id
        && d.workspace in ['national','valcea']
        && d.status in ['new','reviewed','in-progress','waiting','done','dismissed']
        && d.followed is bool
        && d.notes is list
        && d.updatedAt is string
        && (!('reviewedAt' in d) || d.reviewedAt is string)
        && (!('snapshot' in d) || (d.snapshot is map
              && d.snapshot.confidence is number
              && d.snapshot.signalCount is number))
        && (!('draft' in d) || (d.draft is map
              && d.draft.factualSummary is string
              && d.draft.confirmedFacts is list
              && d.draft.unconfirmedClaims is list));
    }
    match /workflow/{id} {
      allow read: if isNewsroom();
      allow create, update: if isNewsroom() && validWorkflow(id);
      allow delete: if isNewsroom();
    }

    // ── Istoricul brief-urilor zilnice — intern ──
    // id = `<workspace>-<date>`; validăm workspace, date, generatedAt și
    // structura counts/sections (map). Per-item storyId e garantat de
    // asamblarea deterministă (buildBrief); regulile nu pot itera nested.
    function validBrief(id) {
      let d = request.resource.data;
      return d.workspace in ['national','valcea']
        && d.date is string
        && d.generatedAt is string
        && d.sections is map
        && d.counts is map
        && id == d.workspace + '-' + d.date;
    }
    match /briefs/{id} {
      allow read: if isNewsroom();
      allow create, update: if isNewsroom() && validBrief(id);
      allow delete: if isNewsroom();
    }
  }
}
